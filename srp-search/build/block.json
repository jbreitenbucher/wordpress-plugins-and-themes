{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "srp/search",
  "title": "SRP Search",
  "category": "wbp-content",
  "icon": "search",
  "description": "Senior Research Project search — query by student name, year, title, major, or advisor.",
  "textdomain": "srp-search",
  "editorScript": "file:./index.js",
  "style": "file:./style.css",
  "editorStyle": "file:./editor.css",
  "supports": {
    "html": false,
    "align": ["wide", "full"]
  },
  "attributes": {
    "perPage": {
      "type": "number",
      "default": 25
    },
    "noResultsMessage": {
      "type": "string",
      "default": "No projects found matching your search."
    },
    "showMajor2": {
      "type": "boolean",
      "default": true
    },
    "showAdvisor": {
      "type": "boolean",
      "default": true
    },
    "orderBy": {
      "type": "string",
      "default": "year_asc_name_asc"
    }
  }
}
